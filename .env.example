# Backend App
SPRING_PROFILES_ACTIVE=dev
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=xpto_db
DB_USER=xpto
DB_PASSWORD=xpto_password

# Database (MongoDB)
MONGO_URI=mongodb://localhost:27017/xpto_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Security / Auth
JWT_SECRET=xpto-local-development-secret-key-2026-high-entropy-security

# Cloudinary (Mock)
CLOUDINARY_URL=cloudinary://mock-api-key:mock-api-secret@mock-cloud-name
CLOUDINARY_CLOUD_NAME=mock-cloud-name
CLOUDINARY_API_KEY=mock-api-key
CLOUDINARY_API_SECRET=mock-api-secret

# Stripe (Mock)
STRIPE_PUBLIC_KEY=pk_test_mock_key
STRIPE_SECRET_KEY=sk_test_mock_key
STRIPE_WEBHOOK_SECRET=whsec_mock_key

# Mail (Brevo) (Mock)
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USER=mock-user@smtp-brevo.com
MAIL_PASS=mock-pass
MAIL_FROM=mock@domain.com
